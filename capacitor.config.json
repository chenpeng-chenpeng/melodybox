{
  "appId": "com.melodybox.player",
  "appName": "MelodyBox",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["*"]
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 500,
      "backgroundColor": "#0a0a0f"
    }
  }
